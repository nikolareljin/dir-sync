# Packaging metadata for dir-sync.
# Use | as a list separator for dependencies to preserve spaces in entries.

APP_NAME="dir-sync"
APP_BIN_NAME="dir-sync"
APP_TITLE="Dir Sync"
APP_VERSION="0.1.0"
APP_DESCRIPTION="Cross-platform toolbar app for rsync-based directory synchronization."
APP_DESCRIPTION_LONG="Dir Sync runs in the system tray and executes one-way or two-way rsync workflows, including removable-drive automations."
APP_HOMEPAGE="https://github.com/nikolareljin/dir-sync"
APP_LICENSE="MIT"
APP_VENDOR="Dir Sync Contributors"

# Build/install commands should honor DESTDIR and PREFIX when possible.
APP_INSTALL_PREFIX="/usr"
APP_BUILD_CMD="make build"
APP_INSTALL_CMD="make install"

MAINTAINER_NAME="Dir Sync Contributors"
MAINTAINER_EMAIL="opensource@users.noreply.github.com"

# Optional repo slug for GitHub source URLs (owner/repo)
SOURCE_REPO="nikolareljin/dir-sync"

# Debian metadata
DEB_SECTION="utils"
DEB_PRIORITY="optional"
DEB_SERIES="jammy"
DEB_ARCH="any"
DEB_BUILD_DEPENDS="debhelper-compat (= 13)|build-essential|python3|python3-pip|rsync"
DEB_DEPENDS="rsync"
DEB_RECOMMENDS=""
DEB_SUGGESTS=""

# RPM metadata
RPM_RELEASE="1%{?dist}"
RPM_BUILD_REQUIRES="make|python3|python3-pip|rsync"
RPM_REQUIRES="rsync"
RPM_FILES="/usr/bin/${APP_BIN_NAME}"

# Arch metadata
ARCH_PKGREL="1"
ARCH_ARCH="x86_64"
ARCH_DEPENDS="rsync"
ARCH_MAKEDEPENDS="git|python|python-pip|make"
ARCH_SOURCE_URL="https://github.com/${SOURCE_REPO}/archive/refs/tags/v${APP_VERSION}.tar.gz"
ARCH_SOURCE_SHA256="SKIP"

# Homebrew metadata
BREW_FORMULA_NAME="dir-sync"
BREW_FORMULA_CLASS="DirSync"
BREW_DESC="Cross-platform rsync directory synchronizer"
BREW_HOMEPAGE="https://github.com/nikolareljin/dir-sync"
BREW_URL="https://github.com/${SOURCE_REPO}/archive/refs/tags/v${APP_VERSION}.tar.gz"
BREW_SHA256="REPLACE_WITH_SHA256"
BREW_LICENSE="MIT"
BREW_DEPENDS="python@3.11|rsync"
BREW_INSTALL_CMD='system "make", "install", "PREFIX=#{prefix}"'
BREW_TEST_CMD='system "#{bin}/dir-sync", "--help"'
