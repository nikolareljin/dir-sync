pkgname=dir-sync
pkgver=0.1.0
pkgrel=1
pkgdesc="Cross-platform toolbar app for rsync-based directory synchronization."
arch=('x86_64')
url="https://github.com/nikolareljin/dir-sync"
license=('MIT')
depends=('rsync')
makedepends=('git' 'python' 'python-pip' 'make')
source=("https://github.com/nikolareljin/dir-sync/archive/refs/tags/v0.1.0.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  make build
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  DESTDIR="${pkgdir}" PREFIX="/usr" make install
}
